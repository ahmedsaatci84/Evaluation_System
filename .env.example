# ============================================================
#  Copy this file to .env and fill in the values.
#  NEVER commit .env to source control.
# ============================================================

# ── Django ───────────────────────────────────────────────────
# Generate a real key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-this-to-a-long-random-string

# Set to True only for local development, never in production
DEBUG=False

# ── SQL Server (used by the Django web container) ─────────────
DB_HOST=db
DB_PORT=1433
DB_NAME=evaluation_db
DB_USER=sa
DB_PASSWORD=YourStrong!Passw0rd

# ── SQL Server SA password (used by the db container itself) ──
# Must match DB_PASSWORD when DB_USER=sa
SA_PASSWORD=YourStrong!Passw0rd

# ── Ollama ────────────────────────────────────────────────────
# Automatically set to http://ollama:11434 in docker-compose.yml
# Override here only if you run Ollama outside Docker
# OLLAMA_HOST=http://ollama:11434
