{% extends "evaluation_app/base.html" %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>قائمة الأساتذة</h1>
    <a href="{% url 'professor_create' %}" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> إضافة أستاذ
    </a>
</div>

{% if messages %}
    {% for message in messages %}
    <div class="alert alert-{{ message.tags }} alert-dismissible fade show" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    {% endfor %}
{% endif %}

{% if professors %}
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>المعرف</th>
                <th>الاسم</th>
                <th>الهاتف</th>
                <th>الإجراءات</th>
            </tr>
        </thead>
        <tbody>
            {% for professor in professors %}
            <tr>
                <td>{{ professor.profid }}</td>
                <td>{{ professor.profname|default:"غير متوفر" }}</td>
                <td>{{ professor.prophone|default:"غير متوفر" }}</td>
                <td>
                    <a href="{% url 'professor_update' professor.profid %}" class="btn btn-sm btn-warning">تعديل</a>
                    <a href="{% url 'professor_delete' professor.profid %}" class="btn btn-sm btn-danger">حذف</a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% else %}
<div class="alert alert-warning" role="alert">
    لم يتم العثور على أساتذة.
</div>
{% endif %}
{% endblock %}
