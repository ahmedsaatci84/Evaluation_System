{% extends "evaluation_app/base.html" %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>قائمة المدربين</h1>
    <a href="{% url 'trainer_create' %}" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> إضافة مدرب
    </a>
</div>

{% if messages %}
    {% for message in messages %}
    <div class="alert alert-{{ message.tags }} alert-dismissible fade show" role="alert">
        {{ message }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    {% endfor %}
{% endif %}

{% if trainers %}
<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>المعرف</th>
                <th>الاسم</th>
                <th>الهاتف</th>
                <th>البريد الإلكتروني</th>
                <th>الإجراءات</th>
            </tr>
        </thead>
        <tbody>
            {% for trainer in trainers %}
            <tr>
                <td>{{ trainer.train_id }}</td>
                <td>{{ trainer.train_name }}</td>
                <td>{{ trainer.train_phone|default:"غير متوفر" }}</td>
                <td>{{ trainer.train_email|default:"غير متوفر" }}</td>
                <td>
                    <a href="{% url 'trainer_update' trainer.train_id %}" class="btn btn-sm btn-warning">تعديل</a>
                    <a href="{% url 'trainer_delete' trainer.train_id %}" class="btn btn-sm btn-danger">حذف</a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% else %}
<div class="alert alert-warning" role="alert">
    لم يتم العثور على مدربين.
</div>
{% endif %}
{% endblock %}
